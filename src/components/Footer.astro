---
import { getCategories } from "../lib/woocommerce";

let categories: Awaited<ReturnType<typeof getCategories>> = [];
try {
  const allCategories = await getCategories();
  const allowedIds = [126, 133, 132, 128];
  

  categories = allCategories.filter((category) => allowedIds.includes(Number(category.id)));
} catch {

}

const FACEBOOK_URL = import.meta.env.PUBLIC_FACEBOOK_URL;
const TWITTER_URL = import.meta.env.PUBLIC_TWITTER_URL;
const YOUTUBE_URL = import.meta.env.PUBLIC_YOUTUBE_URL;
const socials = [
  { name: "Facebook", url: FACEBOOK_URL },
  { name: "Twitter", url: TWITTER_URL },
  { name: "YouTube", url: YOUTUBE_URL },
].filter((s) => s.url);
---

<footer class="site-footer" id="contact">
  <div class="hazard-rule"></div>
  <div class="wrap grid">
    <div class="about">
      <h2>Kiran<br />Enterprises</h2>
      <p>Your trusted partner for premium construction materials. Quality products at competitive prices.</p>
    </div>

    <div class="links">
      <h3>Quick Links</h3>
      <a href="/">Home</a>
      <a href="/products">All Products</a>
    </div>

    <div class="links">
      <h3>Categories</h3>
      {categories.length > 0 ? (
        categories.map((c) => <a href={`/category/${c.slug}`}>{c.name}</a>)
      ) : (
        <a href="/products">All Products</a>
      )}
    </div>

    <div class="contact">
      <h3>Contact Us</h3>
      <a href="https://maps.google.com/?q=Kulshekar+Church+Rd+Bikarnakatte+Kaikamba+Mangaluru" target="_blank" rel="noopener">
        Kulshekar Church Rd, near Holy Cross Church, Bikarnakatte Kaikamba, Mangaluru
      </a>
      <a href="tel:+919845085598">+91 98450 85598</a>
      <a href="mailto:info@thekiranenterprises.co">info@thekiranenterprises.co</a>
    </div>
  </div>

  <div class="credit wrap">
    <span>© {new Date().getFullYear()} Kiran Enterprises</span>
    <span>Designed and developed by Red Media Solutions</span>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--charcoal);
    color: var(--paper);
    margin-top: 40px;
  }

  .grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr 1.4fr;
    gap: 32px;
    padding-block: 48px 32px;
  }

  .about h2 {
    color: var(--paper);
    font-size: 1.7rem;
    margin-bottom: 14px;
  }
  .about p {
    color: #c9c3b7;
    font-size: 0.92rem;
    max-width: 34ch;
  }

  .socials {
    display: flex;
    gap: 10px;
    margin-top: 18px;
  }
  .socials a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(250, 248, 244, 0.1);
    color: var(--paper);
  }
  .socials a:hover {
    background: var(--clay);
  }

  h3 {
    font-size: 1rem;
    color: var(--hazard);
    margin-bottom: 16px;
  }

  .links,
  .contact {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .links a,
  .contact a {
    color: #c9c3b7;
    text-decoration: none;
    font-size: 0.92rem;
  }
  .links a:hover,
  .contact a:hover {
    color: var(--paper);
  }

  .credit {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
    padding-block: 18px;
    border-top: 1px solid rgba(250, 248, 244, 0.12);
    font-family: var(--font-mono);
    font-size: 0.76rem;
    color: #8f897c;
  }

  @media (max-width: 780px) {
    .grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 480px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>