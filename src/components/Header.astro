---
const APP_URL = import.meta.env.PUBLIC_APP_URL;
---

<header class="site-header">
  <div class="wrap bar">
    <a href="/" class="brand" aria-label="Kiran Enterprises home">
      <img src="/logo kiran.png" alt="" width="46" height="46" />
      <span class="brand-name">Kiran<br />Enterprises</span>
    </a>

    <nav class="nav" aria-label="Primary">
      <a href="/">Home</a>
      <a href="/products">All Products</a>
      <a href="/#categories">Categories</a>
      <a href="/#contact">Contact</a>
    </nav>

    <form class="search" action="/products" method="get" role="search">
      <label for="site-search" class="visually-hidden">Search products</label>
      <input id="site-search" type="search" name="search" placeholder="Search cement, paint, tiles…" />
      <button type="submit" aria-label="Search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </button>
    </form>

    <a class="btn btn-primary app-cta" href={APP_URL} target="_blank" rel="noopener">
      Get the App
    </a>

    <button class="menu-toggle" id="menu-toggle" aria-expanded="false" aria-controls="mobile-nav" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="mobile-nav" id="mobile-nav" hidden>
    <a href="/">Home</a>
    <a href="/products">All Products</a>
    <a href="/#categories">Categories</a>
    <a href="/#contact">Contact</a>
    <a class="btn btn-primary" href={APP_URL} target="_blank" rel="noopener">Get the App</a>
  </div>
</header>

<script>
  const toggle = document.getElementById("menu-toggle");
  const panel = document.getElementById("mobile-nav");
  toggle?.addEventListener("click", () => {
    const isOpen = !panel?.hidden;
    if (panel) panel.hidden = isOpen;
    toggle.setAttribute("aria-expanded", String(!isOpen));
  });
</script>

<style>
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }

  .site-header {
    position: sticky;
    top: 0;
    z-index: 40;
    background: var(--paper);
    border-bottom: 1px solid var(--line);
  }

  .bar {
    display: flex;
    align-items: center;
    gap: 24px;
    padding-block: 14px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: var(--charcoal);
    margin-right: auto;
  }

  .brand-name {
    font-family: var(--font-display);
    font-weight: 700;
    text-transform: uppercase;
    line-height: 1;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
  }

  .nav {
    display: flex;
    gap: 22px;
  }

  .nav a {
    text-decoration: none;
    font-weight: 600;
    font-size: 0.92rem;
    color: var(--steel);
  }
  .nav a:hover {
    color: var(--clay-deep);
  }

  .search {
    display: flex;
    align-items: center;
    background: var(--panel);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .search input {
    border: 0;
    background: transparent;
    padding: 9px 10px;
    font-size: 0.88rem;
    width: 190px;
    color: var(--charcoal);
  }
  .search input:focus {
    outline: none;
  }

  .search button {
    border: 0;
    background: transparent;
    padding: 8px 10px;
    display: flex;
    color: var(--steel);
    cursor: pointer;
  }
  .search button:hover {
    color: var(--clay-deep);
  }

  .app-cta {
    padding: 10px 18px;
    font-size: 0.82rem;
    white-space: nowrap;
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: 0;
    cursor: pointer;
    padding: 6px;
  }
  .menu-toggle span {
    width: 22px;
    height: 2px;
    background: var(--charcoal);
  }

  .mobile-nav {
    display: none;
    flex-direction: column;
    gap: 14px;
    padding: 18px clamp(20px, 4vw, 48px) 24px;
    border-top: 1px solid var(--line);
  }
  .mobile-nav a {
    text-decoration: none;
    font-weight: 600;
    color: var(--charcoal);
  }

  @media (max-width: 860px) {
    .nav,
    .search,
    .app-cta {
      display: none;
    }
    .menu-toggle {
      display: flex;
    }
    .mobile-nav:not([hidden]) {
      display: flex;
    }
  }
</style>
